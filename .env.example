# Database
DATABASE_URL=postgresql://preptrack:password@localhost:5432/preptrack

# Server
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://preptrack.yourdomain.com

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Mealie
MEALIE_URL=http://your-mealie-instance:9000
MEALIE_API_KEY=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# TickTick (optional)
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
